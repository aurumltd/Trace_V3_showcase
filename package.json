{
  "name": "trace",
  "version": "1.0.0",
  "description": "Trace - 极简自动时间追溯到系统日历",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "validate:logic": "tsc -p tsconfig.validation.json && node ./.tmp/validation/scripts/run-workblock-validations.js",
    "lint": "eslint src/ --ext .ts,.tsx",
    "lint:fix": "eslint src/ --ext .ts,.tsx --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.1",
    "lucide-react": "^1.8.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.13.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tauri-apps/cli": "^2.1.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.16",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "postcss": "^8.4.32",
    "prettier": "^3.8.2",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0",
    "vite": "^6.4.2"
  }
}
